    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hidmo/config": "workspace:*",
    "@hidmo/contracts": "workspace:*",
    "@hidmo/database": "workspace:*",
    "@hidmo/logging": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}

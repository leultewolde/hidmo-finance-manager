{
  "name": "hidmo-finance-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm db:up && pnpm db:migrate && pnpm dev:apps",
    "dev:apps": "dotenv -e .env -- concurrently --kill-others-on-fail --names web,worker \"pnpm --filter @hidmo/web dev\" \"pnpm --filter @hidmo/worker dev\"",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @hidmo/database db:generate",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "dotenv -e .env -- pnpm --filter @hidmo/database db:migrate",
    "db:reset": "dotenv -e .env -- pnpm --filter @hidmo/database db:reset",
    "db:seed": "dotenv -e .env -- pnpm --filter @hidmo/database db:seed",
    "db:up": "docker compose up -d --wait postgres",
    "container:build": "pnpm container:build:web && docker build --target worker -t hidmo-worker:local . && docker build --target migrations -t hidmo-migrations:local .",
    "container:build:web": "dotenv -e .env -- docker build --target web --build-arg NEXT_PUBLIC_FIREBASE_API_KEY --build-arg NEXT_PUBLIC_FIREBASE_APP_ID --build-arg NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN --build-arg NEXT_PUBLIC_FIREBASE_PROJECT_ID -t hidmo-web:local .",
    "deploy:images:dev": "scripts/publish-dev-images.sh all",
    "deploy:images:dev:web": "scripts/publish-dev-images.sh web",
    "deploy:images:dev:worker": "scripts/publish-dev-images.sh worker",
    "deploy:images:dev:migrations": "scripts/publish-dev-images.sh migrations",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "dotenv -e .env -- vitest run",
    "test:watch": "dotenv -e .env -- vitest",
    "typecheck": "pnpm --filter @hidmo/finance-engine build && pnpm --filter './packages/**' typecheck && pnpm --filter './packages/**' build && pnpm --filter './apps/**' typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "concurrently": "10.0.3",
    "dotenv-cli": "11.0.0",
    "eslint": "10.5.0",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  }
}

{
  "name": "@hidmo/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:reset": "tsx src/cli/reset.ts",
    "db:seed": "tsx src/cli/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hidmo/finance-engine": "workspace:*",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.22.4"
  }
}
